# PostgreSQL
DATABASE_URL=postgresql+asyncpg://syn:syn@localhost:5433/syn

# Qdrant
QDRANT_URL=http://localhost:6333
QDRANT_TRIALS_COLLECTION=syn_trials
QDRANT_PAPERS_COLLECTION=syn_papers

# Redis
REDIS_URL=redis://localhost:6379

# NCBI / PubMed (obligatoire)
NCBI_EMAIL=your-email@example.com
NCBI_API_KEY=

# Embedding
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIM=384

# App
ENVIRONMENT=development
